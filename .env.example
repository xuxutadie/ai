# AI评分API配置
# 复制此文件为 .env 并填写您的API密钥

# OpenAI配置
VITE_OPENAI_API_KEY=your_openai_api_key_here
VITE_OPENAI_MODEL=gpt-3.5-turbo

# 百度文心一言配置
VITE_BAIDU_API_KEY=your_baidu_api_key_here
VITE_BAIDU_SECRET_KEY=your_baidu_secret_key_here

# 阿里通义千问配置
VITE_ALIYUN_API_KEY=your_aliyun_api_key_here

# 智谱GLM配置
VITE_ZHIPU_API_KEY=your_zhipu_api_key_here

# 评分服务开关
VITE_ENABLE_AI_SCORING=true
